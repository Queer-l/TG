  sentences:
  - "\u6765\u5230\u534A\u5C71\u8170\u7684\u5468\u56F4\u77FF\u573A\uFF0C\u7531\u4E8E\u957F\u671F\u91C7\u77FF\uFF0C\u534A\u4E2A\u5C71\u5934\u90FD\u5DF2\u7ECF\u88AB\u524A\u53BB\uFF0C\u5F62\u6210\u4E86\u4E00\u4E2A\u659C\u7F6E\u7684\u6F0F\u6597\u72B6\u3002"
  - "\u6F0F\u6597\u9762\u5411\u5916\u9762\u7684\u90E8\u5206\u5927\u90E8\u5206\u88AB\u94C1\u4E1D\u7F51\u62E6\u4F4F\uFF0C\u96BE\u4EE5\u8FDB\u5165\u3002\u4F46\u591A\u5E74\u7684\u98CE\u971C\u4E5F\u65E9\u5DF2\u5728\u8FD9\u9053\u4E25\u5BC6\u7684\u9632\u7EBF\u4E0A\u6495\u51FA\u8BB8\u591A\u6F0F\u6D1E"
