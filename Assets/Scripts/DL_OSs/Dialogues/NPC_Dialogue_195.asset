  sentences:
  - "\u5C31\u8FD9\u6837\u8FC7\u4E86\u51E0\u5929\uFF0C\u4E00\u79CD\u51B2\u52A8\u4F3C\u4E4E\u64CD\u7EB5\u7740\u7238\u7238\uFF0C\u4ED6\u65F6\u5E38\u5750\u7ACB\u4E0D\u5B89\uFF0C\u6709\u65F6\u4F1A\u56E0\u4E3A\u4E00\u70B9\u9E21\u6BDB\u849C\u76AE\u7684\u5C0F\u4E8B\u800C\u53D8\u5F97\u52C3\u7136\u5927\u6012\u3002\u5728\u6BCF\u65E5\u7684\u9910\u684C\u4E0A\uFF0C\u4ED6\u4E5F\u5F88\u5C11\u5403\u4E1C\u897F\uFF0C\u53CD\u800C\u62FF\u8D77\u4E00\u65C1\u7684\u9152\u74F6\u5B50\uFF0C\u7ED9\u81EA\u5DF1\u7684\u5C0F\u9152\u676F\u6EE1\u4E0A\uFF0C\u7136\u540E\u81EA\u5DF1\u4E00\u996E\u800C\u5C3D\u2014\u2014\u4F46\u662F\u5373\u4F7F\u8FD9\u6837\uFF0C\u5148\u524D\u90A3\u79CD\u5F00\u6717\u7684\u7B11\u5BB9\u4E5F\u4E0D\u518D\u51FA\u73B0\u5728\u4ED6\u8138\u4E0A"
